NODE_ENV=production
PORT=5000
POSTGRES_DB=axtask
POSTGRES_USER=axtask
POSTGRES_PASSWORD=123
DATABASE_URL=postgresql://axtask:123@database:5432/axtask
SESSION_SECRET=123-onetwothree-local-docker-secret-key-min-32
REGISTRATION_MODE=open
CANONICAL_HOST=localhost
FORCE_HTTPS=false
ATTACHMENT_STORAGE_DIR=/app/storage/attachments

# Optional — NodeWeaver classifier in Docker (profile "nodeweaver"). Initialize submodule:
#   services/nodeweaver/upstream — see services/nodeweaver/README.md
# Then: npm run docker:up:nodeweaver
# NODEWEAVER_URL=http://nodeweaver:5000

# Optional (Phase A): baked into the SPA at image build time. Bump after a breaking API/schema change
# so browsers discard old TanStack Query localStorage caches. Rebuild: npm run docker:up / docker:start.
# VITE_QUERY_PERSIST_BUSTER=v1

# Phase B (device refresh): no extra variables here. The compose "migrate" service runs db:push and
# creates device_refresh_tokens. See docs/OFFLINE_PHASE_B.md and docs/DOCKER_FOUNDATION.md#offline-phase-b-device-refresh-database
