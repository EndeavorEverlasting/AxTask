NODE_ENV=production
PORT=5000
POSTGRES_DB=axtask
POSTGRES_USER=axtask
POSTGRES_PASSWORD=replace-me
DATABASE_URL=postgresql://axtask:replace-me@database:5432/axtask
SESSION_SECRET=replace-with-32-plus-char-secret
CANONICAL_HOST=localhost
FORCE_HTTPS=false
ATTACHMENT_STORAGE_DIR=/app/storage/attachments
AXTASK_ALARM_COMPANION_URL=http://host.docker.internal:8787/apply-alarm
# Optional shared secret (must match host companion AXTASK_ALARM_COMPANION_SECRET)
# AXTASK_ALARM_COMPANION_SECRET=
