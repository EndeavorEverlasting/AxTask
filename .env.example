#
# Local development defaults (copy to .env)
# This file is safe to commit. Never commit real secrets in .env.
#

NODE_ENV=development
PORT=5000

# Local Postgres (offline-friendly if running local Postgres/Docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/axtask

# DATABASE_URL must be set at process start (server/db.ts). A wrong host/port yields ECONNREFUSED;
# missing variable exits immediately — that is separate from seed try/catch.

# If Postgres is not running, set to true so npm run dev still skips dev account seeding.
# Other startup seeds in server/routes.ts are wrapped in try/catch and log warnings instead of exiting.
# DISABLE_DEV_SEED=true

# npm run dev — starts the server only (no drizzle-kit push, no migrations/*.sql runner).
# npm run dev:smart — runs scripts/apply-migrations.mjs every time, then db:push when
# shared/schema.ts, drizzle.config.ts, or migrations/*.sql change (see tools/local/offline-start.mjs).
# Full order and diagrams: docs/DEV_DATABASE_AND_SCHEMA.md

# Health: GET /health returns ok if the Node process is up. GET /ready runs SELECT 1 on the pool
# and returns 503 with { status: "not_ready" } if the database is unreachable (useful for orchestration).

# Sessions default to PostgreSQL via connect-pg-simple (see server/auth.ts). The session table is
# created on first use if missing. If Postgres is down after the server has started, routes that touch
# req.session (login, OAuth callback, etc.) can still fail until the database is available.

# Dev only: use in-memory session store so a down Postgres does not break session middleware on first
# request. Sessions do not survive process restart; user lookup/login still requires the database.
# DEV_SESSION_MEMORY_STORE=true

# Required for auth/session signing in local runs
SESSION_SECRET=replace-with-a-32-plus-char-random-secret

# Optional locally: 64 hex chars (32 bytes) encrypting TOTP secrets at rest. In production, set when using authenticator apps.
# TOTP_ENCRYPTION_KEY=


# Keep local host checks dev-friendly
CANONICAL_HOST=localhost
FORCE_HTTPS=false
