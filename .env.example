#
# Local development defaults (copy to .env)
# This file is safe to commit. Never commit real secrets in .env.
#

NODE_ENV=development
PORT=5000

# Local Postgres (offline-friendly if running local Postgres/Docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/axtask

# Required for auth/session signing in local runs
SESSION_SECRET=replace-with-a-32-plus-char-random-secret

# Keep local host checks dev-friendly
CANONICAL_HOST=localhost
FORCE_HTTPS=false

# Optional: short non-secret hint shown on the sign-in screen in development only (e.g. point to your local runbook). Never put passwords here.
# AXTASK_LOGIN_PRETEXT=

# Skip automatic drizzle-kit push before npm run dev / npm start (Docker app service sets this; use locally only if you manage schema yourself)
# SKIP_DB_PUSH_ON_START=true

# Optional — browser push (defaults: server stores VAPID in DB; client uses /api/notifications/push-public-config)
# CANONICAL_HOST or BASE_URL (https) supplies VAPID subject in production
# VITE_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com
# DISABLE_PUSH_DISPATCH=true
# PUSH_DISPATCH_INTERVAL_MS=120000

# Optional — anonymous playstyle cohort rollups (how users “play” gamification / avatars)
# Set interval to enable background recompute (e.g. every 6h). Otherwise use POST /api/admin/playstyle-cohorts/recompute.
# PLAYSTYLE_COHORT_INTERVAL_MS=21600000
# PLAYSTYLE_WINDOW_DAYS=28
# PLAYSTYLE_COHORT_USER_CAP=8000
