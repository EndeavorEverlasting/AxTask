# Build manifests regenerated on every build by scripts/deploy/build-manifest.mjs
dist/build-manifest.json

# Drizzle-kit journal directory (generated by `drizzle-kit generate`/`check`).
# AxTask uses hand-written SQL under migrations/*.sql driven by
# scripts/apply-migrations.mjs, so this meta dir is just a local by-product
# and should never be committed.
migrations/meta/

# Archetype analytics — personal notes and local golden-file dumps that might
# contain raw signal payloads or un-anonymized actor sequences. Never commit.
docs/ARCHETYPE_EMPATHY_ANALYTICS.local.md
server/__archetype_fixtures__/

# Full-scale backup fixtures drop zone (real user JSON exports; real PII).
# Use test-fixtures/account-backup-v1-sample.json in CI; run the zip locally
# via `npm run smoke:v1-zip`.
#
# The scanner in scripts/smoke-v1-backup-zip.mjs auto-picks up any docs/*.json
# whose filename contains backup / axtask / import, so ignore the extracted
# JSONs with matching patterns too — an unclean working tree must never be
# able to leak PII-bearing backup contents.
docs/*backup*.json
docs/*axtask*.json
docs/*import*.json
.tmp-*.txt
.tmp-*.log

# Local branch drop-zone for scratch bundles and copied scaffolds
branches/axtask_command_engine_foundation/
branches/*.zip
docs/releases/*.local.md

# --- PII and other sensitive local artifacts (never commit) ---
# Ad-hoc backup/import zips under docs (filenames often contain real names).
docs/**/*.zip
