{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx server/index.ts",
    "start:local": "node tools/local/offline-start.mjs",
    "dev:smart": "node tools/local/offline-start.mjs",
    "offline:start": "node tools/local/offline-start.mjs",
    "offline:shortcut": "powershell -ExecutionPolicy Bypass -File tools/local/create-desktop-shortcut.ps1",
    "git:checkpoint": "powershell -ExecutionPolicy Bypass -File scripts/git-checkpoint.ps1",
    "release:check": "node scripts/release-check.mjs",
    "local:env-init": "node tools/local/copy-env-local.mjs",
    "docker:start": "docker compose --env-file .env.docker up -d --build",
    "docker:stop": "docker compose --env-file .env.docker down",
    "docker:status": "docker compose --env-file .env.docker ps",
    "docker:logs": "docker compose --env-file .env.docker logs --tail 100",
    "alarm:companion:start": "node tools/alarm-companion/server.mjs",
    "alarm:companion:start:dev": "node tools/alarm-companion/server.mjs",
    "deps:sync": "node tools/local/sync-deps.mjs",
    "pr:factor": "node tools/local/pr-factor.mjs plan --base origin/main --max-files 200",
    "pr:factor:scan": "node tools/local/pr-factor.mjs scan --base origin/main",
    "pr:factor:classify": "node tools/local/pr-factor.mjs classify --base origin/main",
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "cross-env NODE_ENV=production node scripts/production-start.mjs",
    "start:app": "cross-env NODE_ENV=production node dist/index.js",
    "check": "tsc",
    "security:node-provenance-guard": "node tools/security/check_node_provenance.mjs",
    "security:node-provenance:approve-local": "node tools/security/approve_local_node_provenance.mjs",
    "security:node-runtime-guard": "node tools/security/check_node_runtime.mjs",
    "security:axios-guard": "node tools/security/check_no_axios.mjs",
    "test": "vitest run",
    "perf:bundle": "node tools/perf/bundle-budget.mjs",
    "perf:api-replay": "tsx tools/perf/api-replay.mjs",
    "perf:ci": "npm run build && npm run perf:bundle && npm run perf:api-replay",
    "test:deploy:contract": "vitest run tests/deploy/00-contract",
    "test:deploy:env": "node scripts/deploy/check-env.mjs --dev && vitest run tests/deploy/01-env",
    "test:deploy:artifacts": "vitest run tests/deploy/03-artifacts",
    "test:deploy:migrations": "vitest run tests/deploy/04-migrations",
    "test:deploy:health": "vitest run tests/deploy/06-health",
    "test:deploy:regression": "vitest run tests/deploy/08-regression",
    "test:deploy:classify": "vitest run tests/deploy/09-failure-classification",
    "test:deploy:capacity": "node scripts/deploy/check-db-capacity.mjs",
    "test:deploy": "npm run test:deploy:contract && npm run test:deploy:env && npm run test:deploy:artifacts && npm run test:deploy:migrations && npm run test:deploy:health && npm run test:deploy:regression && npm run test:deploy:classify",
    "deploy:build-manifest": "node scripts/deploy/build-manifest.mjs",
    "test:objective-contracts": "vitest run server/use-case-engagement.contract.test.ts server/release-2026-routes-contract.test.ts server/notification-preferences.contract.test.ts server/calendar-holidays.contract.test.ts server/csp-reporting.contract.test.ts client/src/lib/feedback-nudge.test.ts client/src/lib/install-device-state.test.ts shared/public-client-dtos.test.ts",
    "test:docs-contracts": "vitest run server/docs-contracts/docs-doctrine-contract.test.ts server/docs-contracts/docs-privacy-contract.test.ts",
    "check:startup-seeds": "vitest run server/startup-seeds.guard.test.ts",
    "test:watch": "vitest",
    "test:pg-schema": "cross-env RUN_PG_SCHEMA_TESTS=1 vitest run server/users-schema-pg.integration.test.ts",
    "db:push": "node scripts/drizzle-push.mjs",
    "db:migrate": "node -r dotenv/config scripts/apply-migrations.mjs",
    "db:push:ci": "drizzle-kit push --force",
    "db:push:verify": "node scripts/verify-drizzle-deploy.mjs",
    "db:size-audit": "node scripts/db-size-audit.mjs",
    "db:reclaim": "node scripts/db-reclaim.mjs",
    "db:retention": "node scripts/db-retention.mjs",
    "vapid:generate": "node scripts/generate-vapid-keys.mjs",
    "intent:smoke": "tsx scripts/intent-smoke.mts",
    "smoke:v1-zip": "node scripts/smoke-v1-backup-zip.mjs",
    "postinstall": "node -e \"if(require('fs').existsSync('tools/billing_bridge/setup-python.mjs')){require('child_process').execSync('node tools/billing_bridge/setup-python.mjs',{stdio:'inherit'})}else{console.log('[billing-bridge] setup script not found, skipping')}\"",
    "billing-bridge:setup": "node tools/billing_bridge/setup-python.mjs",
    "migration:verify-schema": "node scripts/migration/verify-schema.mjs",
    "migration:smoke-api": "node scripts/migration/smoke-api.mjs",
    "migration:check": "node scripts/migration/run-migration-checks.mjs",
    "migration:check:full": "cross-env RUN_TESTS=1 node scripts/migration/run-migration-checks.mjs"
  },
