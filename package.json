{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx server/index.ts",
    "offline:start": "node tools/local/offline-start.mjs",
    "offline:shortcut": "powershell -ExecutionPolicy Bypass -File tools/local/create-desktop-shortcut.ps1",
    "docker:start": "docker compose --env-file .env.docker up -d --build",
    "docker:stop": "docker compose --env-file .env.docker down",
    "docker:status": "docker compose --env-file .env.docker ps",
    "docker:logs": "docker compose --env-file .env.docker logs --tail 100",
    "deps:sync": "node tools/local/sync-deps.mjs",
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "check": "tsc",
    "security:node-provenance-guard": "node tools/security/check_node_provenance.mjs",
    "security:node-provenance:approve-local": "node tools/security/approve_local_node_provenance.mjs",
    "security:node-runtime-guard": "node tools/security/check_node_runtime.mjs",
    "security:axios-guard": "node tools/security/check_no_axios.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:push": "drizzle-kit push"
  },
