
# Production Environment Variables Template
# Copy this to .env (local) or configure in your hosting platform

# Database
DATABASE_URL=postgresql://user:password@host:5432/database

# Google API Credentials
GOOGLE_CLIENT_ID=your-oauth-client-id
GOOGLE_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_SHEETS_API_KEY=your-api-key

# Application Configuration
NODE_ENV=production
PORT=5000
FORCE_HTTPS=true

# Primary domain used for redirects when unknown hosts hit the app.
# Leave empty if you do not want host canonicalization.
CANONICAL_HOST=app.your-domain.com

# Keep Replit active as immediate fallback target during migration.
REPLIT_FALLBACK_HOST=your-repl-name.replit.app

# Optional comma-separated allowlists for blue/green and temporary hosts.
# ADDITIONAL_ALLOWED_HOSTS=staging.your-domain.com
# ADDITIONAL_ALLOWED_ORIGINS=https://staging.your-domain.com

# Your application's public URL (REQUIRED for OAuth callbacks)
BASE_URL=https://your-domain.com

# Session Security
SESSION_SECRET=generate-a-random-256-bit-key

# --- Archetype empathy analytics (docs/ARCHETYPE_EMPATHY_ANALYTICS.md) ---
# REQUIRED in production. HMAC salt for hashActor(). Must be >=16 chars.
# The server throws on startup if this is missing in NODE_ENV=production.
# Rotating this invalidates Markov chain continuity for any existing hashed
# actors — treat as a long-lived secret.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ARCHETYPE_ANALYTICS_SALT=generate-a-64-hex-char-random-value

# Optional. Grants RAG / analytics services read access to
# /api/archetypes/empathy and /api/archetypes/markov without an admin session,
# via the X-AxTask-Archetype-Token header. Leave blank if only admins need
# access.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# ARCHETYPE_READ_TOKEN=

# Optional. Rollup worker tick interval in ms. Default 3600000 (1h).
# ARCHETYPE_ROLLUP_INTERVAL_MS=3600000

# Optional. Set to "true" to disable the background rollup ticker (for
# external-scheduler deployments).
# DISABLE_ARCHETYPE_ROLLUP=false
